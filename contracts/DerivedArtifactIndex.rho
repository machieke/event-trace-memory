  |

  contract derivedArtifactIndex(@"beliefHistoriesByClaim", @claimId, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "claimId": claimId,
        "historyIds": state.getOrElse("beliefRevisionHistoriesByClaim", {}).getOrElse(claimId, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"beliefHistoriesByOutput", @outputId, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "outputId": outputId,
        "historyIds": state.getOrElse("beliefRevisionHistoriesByOutput", {}).getOrElse(outputId, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"getStateStats", return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "runs": state.getOrElse("runs", {}).size(),
        "claims": state.getOrElse("claims", {}).size(),
        "claimOccurrences": state.getOrElse("claimOccurrences", {}).size(),
        "features": state.getOrElse("features", {}).size(),
        "featureOccurrences": state.getOrElse("featureOccurrences", {}).size(),
        "patterns": state.getOrElse("patterns", {}).size(),
        "patternOccurrences": state.getOrElse("patternOccurrences", {}).size(),
        "reasoningInputs": state.getOrElse("reasoningInputs", {}).size(),
        "reasoningOutputs": state.getOrElse("reasoningOutputs", {}).size(),
        "beliefRevisionHistories": state.getOrElse("beliefRevisionHistories", {}).size()
      })
    }
  }

  |

  insertArbitrary!(bundle+{*derivedArtifactIndex}, *uriCh)
  |
  for (@uri <- uriCh) {
    stdout!(["DerivedArtifactIndex URI: ", uri])
    |
    @"event-trace-memory:DerivedArtifactIndexUri"!(uri)
  }
}
