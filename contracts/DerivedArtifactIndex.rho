  |

  contract derivedArtifactIndex(@"byReasoner", @reasonerKey, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "reasonerKey": reasonerKey,
        "runIds": state.getOrElse("runsByReasoner", {}).getOrElse(reasonerKey, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"byPattern", @patternId, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "patternId": patternId,
        "occurrenceIds": state.getOrElse("occurrencesByPattern", {}).getOrElse(patternId, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"byPatternRoot", @rootEventId, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "rootEventId": rootEventId,
        "occurrenceIds": state.getOrElse("patternOccurrencesByRoot", {}).getOrElse(rootEventId, [])
      })
