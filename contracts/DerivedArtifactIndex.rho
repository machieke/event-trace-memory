        "occurrenceIds": state.getOrElse("featureOccurrencesByFeature", {}).getOrElse(featureId, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"byRun", @runId, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "runId": runId,
        "artifactIds": state.getOrElse("outputsByRun", {}).getOrElse(runId, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"byExtractor", @extractorKey, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "extractorKey": extractorKey,
        "runIds": state.getOrElse("runsByExtractor", {}).getOrElse(extractorKey, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"byMiner", @minerKey, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "minerKey": minerKey,
        "runIds": state.getOrElse("runsByMiner", {}).getOrElse(minerKey, [])
      })
    }
