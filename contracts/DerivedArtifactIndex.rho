  |

  contract derivedArtifactIndex(@"clustersForClaim", @claimId, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "claimId": claimId,
        "clusterIds": state.getOrElse("clustersByClaim", {}).getOrElse(claimId, [])
      })
    }
  }

  |

  contract derivedArtifactIndex(@"reasoningOutputsByInput", @inputId, return) = {
    for (@state <- stateCh) {
      stateCh!(state)
      |
      return!({
        "ok": true,
        "inputId": inputId,
        "outputIds": state.getOrElse("reasoningOutputsByInput", {}).getOrElse(inputId, [])
      })
